                <Dumbbell className="mx-auto mb-1 h-4 w-4" />
                <div className="font-semibold">5 días</div>
                <div className="text-xs text-slate-500">entreno</div>
              </div>
            </div>
            <div className="flex gap-2 pt-1">
              <Button variant="outline" className="flex-1 rounded-2xl" onClick={resetCurrentWeek}>
                <RotateCcw className="mr-2 h-4 w-4" /> Reiniciar semana
              </Button>
              <Button variant="secondary" className="flex-1 rounded-2xl">
                <Save className="mr-2 h-4 w-4" /> Guardado auto
              </Button>
            </div>
          </CardContent>
        </Card>

        <Tabs defaultValue="hoy" className="space-y-4">
          <TabsList className="grid w-full grid-cols-4 rounded-2xl">
            <TabsTrigger value="hoy">Hoy</TabsTrigger>
            <TabsTrigger value="semana">Semana</TabsTrigger>
            <TabsTrigger value="peso">Peso</TabsTrigger>
            <TabsTrigger value="historial">Historial</TabsTrigger>
          </TabsList>

          <TabsContent value="hoy" className="space-y-4">
            <Card className="rounded-3xl border-0 shadow-sm">
              <CardHeader className="pb-2">
                <div className="flex items-center gap-2">
                  <CalendarDays className="h-5 w-5" />
                  <CardTitle className="text-lg">Día actual</CardTitle>
                </div>
                <div className="flex gap-2 overflow-x-auto pb-1">
                  {planBase.map((d, i) => (
