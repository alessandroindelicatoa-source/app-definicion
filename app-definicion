                <div className="text-xs text-slate-500">kcal aprox.</div>
              </div>
              <div className="rounded-2xl bg-white p-3 shadow-sm">
                <Utensils className="mx-auto mb-1 h-4 w-4" />
                <div className="font-semibold">140 g</div>
                <div className="text-xs text-slate-500">proteína</div>
              </div>
