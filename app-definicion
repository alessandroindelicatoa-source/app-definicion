                            <Badge variant="secondary">{exercise.sets}</Badge>
                          </div>
                          <div className="mt-2 flex items-center gap-2">
                            <Input
                              value={currentWeek.weights[`${appState.selectedDay}-${idx}`] ?? ""}
                              onChange={(e) => setExerciseWeight(appState.selectedDay, idx, e.target.value)}
