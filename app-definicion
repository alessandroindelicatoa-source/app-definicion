const mealKeys = ["desayuno", "comida", "cena", "snack"];
const STORAGE_KEY = "plan_definicion_auto_v2";

function getISOWeek(date = new Date()) {
  const tmp = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
  const dayNum = tmp.getUTCDay() || 7;
  tmp.setUTCDate(tmp.getUTCDate() + 4 - dayNum);
  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));
  const weekNo = Math.ceil((((tmp - yearStart) / 86400000) + 1) / 7);
  return { year: tmp.getUTCFullYear(), week: weekNo };
}

function getWeekId(date = new Date()) {
  const { year, week } = getISOWeek(date);
  return `${year}-W${String(week).padStart(2, "0")}`;
}

function getDefaultState() {
  return {
    currentWeekId: getWeekId(),
    selectedDay: 0,
    weeks: {
      [getWeekId()]: {
        checks: {},
        weights: {},
        bodyWeight: "72",
        notes: "",
      },
    },
    history: [],
  };
}

function ensureWeekExists(state, weekId) {
  if (!state.weeks[weekId]) {
    state.weeks[weekId] = {
      checks: {},
      weights: {},
      bodyWeight: "",
      notes: "",
    };
  }
  return state;
}

export default function AppDefinicionMovil() {
  const [appState, setAppState] = useState(getDefaultState);
  const [loaded, setLoaded] = useState(false);

  useEffect(() => {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        const parsed = JSON.parse(saved);
        const currentWeekId = getWeekId();
        const merged = ensureWeekExists({ ...getDefaultState(), ...parsed, weeks: { ...(parsed.weeks || {}) }, history: parsed.history || [] }, currentWeekId);
        setAppState(merged);
      }
    } catch (e) {
      console.error(e);
    } finally {
      setLoaded(true);
    }
  }, []);

  useEffect(() => {
    if (!loaded) return;
    const nowWeekId = getWeekId();
    setAppState((prev) => {
      const next = { ...prev, weeks: { ...prev.weeks }, history: [...(prev.history || [])] };
      if (prev.currentWeekId !== nowWeekId) {
        const oldWeekData = prev.weeks[prev.currentWeekId];
        if (oldWeekData) {
          const oldSummary = calculateWeekSummary(oldWeekData.checks, prev.currentWeekId);
          next.history = [
            {
              weekId: prev.currentWeekId,
              bodyWeight: oldWeekData.bodyWeight || "",
              completion: oldSummary.progress,
            },
            ...next.history.filter((item) => item.weekId !== prev.currentWeekId),
          ].slice(0, 12);
        }
        next.currentWeekId = nowWeekId;
        if (!next.weeks[nowWeekId]) {
          next.weeks[nowWeekId] = {
            checks: {},
            weights: {},
            bodyWeight: prev.weeks[prev.currentWeekId]?.bodyWeight || "",
            notes: "",
          };
        }
      }
      return next;
    });
  }, [loaded]);

  useEffect(() => {
    if (!loaded) return;
    localStorage.setItem(STORAGE_KEY, JSON.stringify(appState));
  }, [appState, loaded]);

  const currentWeek = appState.weeks[appState.currentWeekId] || { checks: {}, weights: {}, bodyWeight: "", notes: "" };
  const current = planBase[appState.selectedDay];

  function updateWeek(patch) {
    setAppState((prev) => ({
      ...prev,
      weeks: {
        ...prev.weeks,
        [prev.currentWeekId]: {
          ...prev.weeks[prev.currentWeekId],
          ...patch,
        },
      },
    }));
  }

  function toggleCheck(key) {
    updateWeek({
      checks: {
        ...currentWeek.checks,
        [key]: !currentWeek.checks[key],
      },
    });
  }

  function setExerciseWeight(dayIdx, exIdx, value) {
    updateWeek({
      weights: {
        ...currentWeek.weights,
        [`${dayIdx}-${exIdx}`]: value,
      },
    });
  }

  function resetCurrentWeek() {
    updateWeek({ checks: {}, weights: {}, notes: "" });
  }

  const totalTasks = useMemo(() => {
    const mealTasks = planBase.length * 4;
    const trainTasks = planBase.reduce((acc, d) => acc + d.training.length, 0);
    return mealTasks + trainTasks;
  }, []);

  const completedTasks = useMemo(() => Object.values(currentWeek.checks).filter(Boolean).length, [currentWeek.checks]);
  const progress = Math.round((completedTasks / totalTasks) * 100);

  const todayScore = useMemo(() => {
    const mealCount = mealKeys.filter((k) => currentWeek.checks[`${appState.selectedDay}-meal-${k}`]).length;
    const trainCount = current.training.filter((_, i) => currentWeek.checks[`${appState.selectedDay}-train-${i}`]).length;
    return { mealCount, trainCount, totalMeals: 4, totalTrain: current.training.length };
  }, [currentWeek.checks, appState.selectedDay, current.training]);

  const historyWithCurrent = useMemo(() => {
    const unique = [
      {
        weekId: appState.currentWeekId,
        bodyWeight: currentWeek.bodyWeight || "",
        completion: progress,
      },
      ...(appState.history || []),
    ].filter((item, idx, arr) => arr.findIndex((x) => x.weekId === item.weekId) === idx);
    return unique.slice(0, 12);
  }, [appState.currentWeekId, currentWeek.bodyWeight, progress, appState.history]);

