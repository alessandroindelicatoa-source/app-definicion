              </div>
              <Badge className="rounded-full px-3 py-1 text-sm">72 kg · 1.64 m</Badge>
            </div>
          </CardHeader>
          <CardContent className="space-y-3">
            <div className="flex items-center justify-between text-sm">
              <span className="font-medium">Semana activa</span>
              <span>{appState.currentWeekId}</span>
            </div>
            <div className="flex items-center justify-between text-sm">
              <span className="font-medium">Progreso semanal</span>
              <span>{progress}%</span>
            </div>
            <Progress value={progress} className="h-3" />
            <div className="grid grid-cols-3 gap-2 pt-1 text-center text-sm">
              <div className="rounded-2xl bg-white p-3 shadow-sm">
