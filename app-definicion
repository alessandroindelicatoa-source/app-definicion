              </CardHeader>
              <CardContent className="space-y-3">
                {planBase.map((d, i) => {
                  const doneMeals = mealKeys.filter((k) => currentWeek.checks[`${i}-meal-${k}`]).length;
                  const doneTrain = d.training.filter((_, idx) => currentWeek.checks[`${i}-train-${idx}`]).length;
                  const total = 4 + d.training.length;
                  const done = doneMeals + doneTrain;
                  const pct = Math.round((done / total) * 100);
                  return (
                    <div key={d.day} className="rounded-2xl bg-white p-3 shadow-sm">
                      <div className="mb-2 flex items-center justify-between">
                        <span className="font-semibold">{d.day}</span>
                        <span className="text-sm text-slate-500">{done}/{total}</span>
                      </div>
                      <Progress value={pct} className="h-2" />
                    </div>
                  );
                })}
                <div className="rounded-2xl bg-emerald-50 p-4 text-sm text-emerald-900">
                  Objetivo: completar al menos 80% de la semana.
                </div>
              </CardContent>
            </Card>
          </TabsContent>

          <TabsContent value="peso" className="space-y-4">
            <Card className="rounded-3xl border-0 shadow-sm">
              <CardHeader>
                <div className="flex items-center gap-2">
                  <Scale className="h-5 w-5" />
                  <CardTitle className="text-lg">Registro semanal de peso</CardTitle>
                </div>
              </CardHeader>
              <CardContent className="space-y-3">
                <div className="rounded-2xl bg-white p-3 shadow-sm">
                  <div className="mb-2 text-sm font-semibold">Semana {appState.currentWeekId}</div>
                  <Input
                    value={currentWeek.bodyWeight}
                    onChange={(e) => updateWeek({ bodyWeight: e.target.value })}
                    placeholder="Ej. 71.4"
                    className="rounded-xl"
                  />
                </div>
                <div className="rounded-2xl bg-white p-3 shadow-sm">
                  <div className="mb-2 text-sm font-semibold">Notas</div>
                  <textarea
                    value={currentWeek.notes}
                    onChange={(e) => updateWeek({ notes: e.target.value })}
                    placeholder="Hambre, energía, si subiste pesos, si dormiste bien..."
                    className="min-h-[110px] w-full rounded-xl border border-slate-200 p-3 text-sm outline-none"
                  />
                </div>
                <div className="rounded-2xl bg-emerald-50 p-4 text-sm text-emerald-900">
                  <div className="mb-1 flex items-center gap-2 font-semibold">
                    <CheckCircle2 className="h-4 w-4" />
                    Objetivo realista
                  </div>
                  Bajar entre 0.4 y 0.7 kg por semana manteniendo fuerza en máquinas.
                </div>
              </CardContent>
            </Card>
          </TabsContent>

          <TabsContent value="historial" className="space-y-4">
            <Card className="rounded-3xl border-0 shadow-sm">
              <CardHeader>
                <CardTitle className="text-lg">Historial automático</CardTitle>
              </CardHeader>
              <CardContent className="space-y-3">
                {historyWithCurrent.map((item) => (
                  <div key={item.weekId} className="rounded-2xl bg-white p-3 shadow-sm">
                    <div className="flex items-center justify-between">
                      <span className="font-semibold">{item.weekId}</span>
                      <Badge variant="secondary">{item.completion}%</Badge>
                    </div>
                    <div className="mt-2 text-sm text-slate-600">Peso: {item.bodyWeight || "—"} kg</div>
                  </div>
                ))}
              </CardContent>
            </Card>
          </TabsContent>
        </Tabs>
      </div>
    </div>
  );
}

function calculateWeekSummary(checks, weekId) {
  const totalTasks = planBase.length * 4 + planBase.reduce((acc, d) => acc + d.training.length, 0);
  const completed = Object.values(checks || {}).filter(Boolean).length;
  return {
    weekId,
    progress: Math.round((completed / totalTasks) * 100),
  };
}
